<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Enea Memory — Tenis</title>
<style>
  :root{--navy:#15275f;--gold:#caa84a;--orange:#f39200;--shadow:0 18px 40px rgba(6,16,45,.45);}
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  html,body{height:100%}
  body{font-family:"Segoe UI",system-ui,-apple-system,Roboto,Arial,sans-serif;background:#0c1838;color:#fff;display:flex;justify-content:center}
  .app{position:relative;width:100%;max-width:460px;min-height:100vh;overflow:hidden;display:flex;flex-direction:column;
       background:#0c1838 center top/cover no-repeat;background-image:url("data:image/jpeg;base64,")}
  /* wideo-tlo */
  .bgvid{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
  .bg-overlay{position:absolute;inset:0;z-index:1;pointer-events:none;
       background:linear-gradient(180deg,rgba(8,20,55,.45),rgba(8,18,48,.62))}
  .screen{position:relative;z-index:2;flex:1;display:none;flex-direction:column}
  .screen.active{display:flex}

  #start{align-items:center;padding:0 22px 30px}
  .logo-enea{margin-top:11vh;width:200px;max-width:55%;filter:drop-shadow(0 4px 10px rgba(0,40,90,.5))}
  .btn-start{margin-top:26px;background:linear-gradient(180deg,#1f3576,#15275f);color:#fff;border:none;border-radius:42px;padding:22px 70px;font-size:46px;font-weight:800;letter-spacing:3px;cursor:pointer;box-shadow:0 14px 30px rgba(8,20,55,.55),inset 0 2px 0 rgba(255,255,255,.12);text-shadow:0 3px 8px rgba(0,0,0,.45);transition:transform .12s}
  .btn-start:active{transform:scale(.97)}
  .rank-card{margin-top:34px;width:100%;background:linear-gradient(180deg,rgba(20,34,80,.92),rgba(16,28,68,.92));border-radius:26px;padding:22px 20px 18px;box-shadow:var(--shadow);border:1px solid rgba(120,150,220,.18);backdrop-filter:blur(3px)}
  .rank-card h2{text-align:center;font-size:30px;font-weight:800;letter-spacing:2px;margin-bottom:16px}
  .rank-head{display:grid;grid-template-columns:46px 1fr auto auto;gap:14px;padding:0 12px 8px;font-size:12px;letter-spacing:1.5px;color:#8fa0cf;font-weight:700}
  .rank-head .c-pts{text-align:right;min-width:64px}.rank-head .c-time{text-align:right;min-width:78px;padding-left:8px}
  .rank-row{display:grid;grid-template-columns:46px 1fr auto auto;gap:14px;align-items:center;background:linear-gradient(90deg,rgba(202,168,74,.30),rgba(202,168,74,.10));border:1px solid rgba(202,168,74,.55);border-radius:16px;padding:12px;margin-bottom:8px;font-weight:700}
  .medal{width:34px;height:34px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:radial-gradient(circle at 35% 30%,#ffd34d,#e0a019);box-shadow:0 2px 6px rgba(0,0,0,.3);font-size:15px;font-weight:800;color:#7a5500}
  .rank-row .nm{font-size:17px}.rank-row .pts{text-align:right;min-width:64px}
  .rank-row .tm{text-align:right;min-width:78px;padding-left:8px;font-variant-numeric:tabular-nums}
  .rank-row.alt{background:rgba(255,255,255,.05);border-color:rgba(140,160,210,.25)}
  .rank-row.alt .medal{background:#46598f;color:#cdd8f5}
  .rank-more{display:block;width:100%;background:none;border:none;color:#fff;cursor:pointer;text-align:center;font-weight:800;letter-spacing:1.5px;font-size:14px;padding:12px 0 4px}
  .rank-empty{text-align:center;color:#9fb0d8;padding:14px 0;font-size:14px}

  #game{padding:16px 14px 24px}
  .g-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
  .g-top .logo-mini{width:86px}
  .g-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:14px}
  .stat{background:linear-gradient(180deg,rgba(20,34,80,.88),rgba(14,26,64,.88));border:1px solid rgba(120,150,220,.2);border-radius:14px;padding:9px;text-align:center;backdrop-filter:blur(3px)}
  .stat .k{font-size:10px;letter-spacing:1.5px;color:#8fa0cf;font-weight:700;text-transform:uppercase}
  .stat .v{font-size:21px;font-weight:800;font-variant-numeric:tabular-nums;margin-top:2px}
  .board{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
  .card{aspect-ratio:1/1.12;perspective:800px;cursor:pointer;background:none;border:none;padding:0}
  .inner{position:relative;width:100%;height:100%;transition:transform .45s cubic-bezier(.2,.8,.3,1);transform-style:preserve-3d}
  .card.flipped .inner,.card.matched .inner{transform:rotateY(180deg)}
  .face{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;border-radius:16px;backface-visibility:hidden;overflow:hidden;box-shadow:0 6px 14px rgba(6,16,45,.4)}
  .front{background:linear-gradient(160deg,#17326f,#0f2150);border:1px solid rgba(120,150,220,.25)}
  .front img{width:74%;height:auto}
  .back{transform:rotateY(180deg);background:#eef4fb;border:1px solid rgba(120,150,220,.3)}
  .back img{width:100%;height:100%;object-fit:cover}
  .card.matched .face{box-shadow:0 0 0 3px var(--gold),0 6px 14px rgba(6,16,45,.4)}
  .card.matched{animation:pop .4s ease}
  @keyframes pop{0%{transform:scale(1)}40%{transform:scale(1.05)}100%{transform:scale(1)}}
  .g-actions{display:flex;justify-content:center;margin-top:16px}
  .btn-ghost{background:rgba(255,255,255,.14);color:#fff;border:1px solid rgba(255,255,255,.3);border-radius:12px;padding:11px 22px;font-weight:700;cursor:pointer;font-size:14px;backdrop-filter:blur(4px)}

  .overlay{position:fixed;inset:0;background:rgba(7,17,45,.82);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;padding:22px;z-index:30}
  .overlay.show{display:flex;animation:fade .3s ease}@keyframes fade{from{opacity:0}to{opacity:1}}
  .modal{background:#fff;color:#15275f;border-radius:24px;max-width:380px;width:100%;padding:30px 26px;text-align:center;box-shadow:var(--shadow);position:relative;overflow:hidden}
  .modal::before{content:"";position:absolute;top:0;left:0;right:0;height:8px;background:linear-gradient(90deg,#caa84a,#ffd34d)}
  .modal .trophy{font-size:54px}.modal h2{font-size:25px;margin:6px 0 4px}.modal p{color:#7d89a8;margin-bottom:8px;font-size:14px}
  .score-row{display:flex;justify-content:center;gap:26px;margin:14px 0 18px}
  .score-row div span{display:block;font-size:11px;color:#7d89a8;text-transform:uppercase;letter-spacing:1px;font-weight:700}
  .score-row div b{font-size:23px;font-variant-numeric:tabular-nums}
  .modal input{width:100%;padding:14px 16px;border-radius:14px;border:2px solid rgba(140,160,210,.4);background:#f3f6fc;color:#15275f;font-size:17px;font-weight:600;outline:none;text-align:center;margin-bottom:14px}
  .modal input:focus{border-color:var(--orange)}
  .btn-go{width:100%;background:linear-gradient(180deg,#1f3576,#15275f);color:#fff;border:none;border-radius:42px;padding:15px;font-size:19px;font-weight:800;letter-spacing:1.5px;cursor:pointer;box-shadow:0 10px 22px rgba(8,20,55,.5)}
  .btn-go:active{transform:scale(.98)}
  .rmodal{background:linear-gradient(180deg,#1b2c66,#101c44);color:#fff;max-width:420px;width:100%;border-radius:24px;padding:26px 22px;box-shadow:var(--shadow);max-height:82vh;overflow:auto}
  .rmodal h2{text-align:center;letter-spacing:2px;margin-bottom:16px}
  .btn-close{margin-top:16px;width:100%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.25);color:#fff;border-radius:14px;padding:12px;font-weight:700;cursor:pointer}
</style>
</head>
<body>
<div class="app" id="appBg">
  <video class="bgvid" autoplay loop muted playsinline disablepictureinpicture></video>
  <div class="bg-overlay"></div>

  <section class="screen active" id="start">
    <img class="logo-enea" src="data:image/png;base64," alt="Enea">
    <button class="btn-start" id="btnStart">START</button>
    <div class="rank-card">
      <h2>RANKING</h2>
      <div class="rank-head"><span>LP.</span><span>NAZWA</span><span class="c-pts">PUNKTY</span><span class="c-time">CZAS</span></div>
      <div id="rankTop"></div>
      <button class="rank-more" id="rankMore">ZOBACZ PEŁNY RANKING</button>
    </div>
  </section>

  <section class="screen" id="game">
    <div class="g-top">
      <img class="logo-mini" src="data:image/png;base64," alt="Enea">
      <button class="btn-ghost" id="btnQuit">Wyjdź</button>
    </div>
    <div class="g-stats">
      <div class="stat"><div class="k">Ruchy</div><div class="v" id="moves">0</div></div>
      <div class="stat"><div class="k">Pary</div><div class="v" id="pairs">0/8</div></div>
      <div class="stat"><div class="k">Czas</div><div class="v" id="time">00:00.000</div></div>
    </div>
    <div class="board" id="board"></div>
    <div class="g-actions"><button class="btn-ghost" id="btnRestart">Od nowa</button></div>
  </section>
</div>

<div class="overlay" id="winOverlay">
  <div class="modal">
    <div class="trophy">🏆</div>
    <h2>Gem, set, mecz!</h2>
    <p>Wszystkie pary znalezione. Zapisz swój wynik w rankingu.</p>
    <div class="score-row"><div><span>Punkty</span><b id="winPts">8.00</b></div><div><span>Czas</span><b id="winTime">00:00.000</b></div></div>
    <input id="playerName" maxlength="18" placeholder="Twoje imię lub nick" autocomplete="off">
    <button class="btn-go" id="btnSave">ZAPISZ WYNIK</button>
  </div>
</div>
<div class="overlay" id="rankOverlay">
  <div class="rmodal">
    <h2>PEŁNY RANKING</h2>
    <div class="rank-head" style="grid-template-columns:46px 1fr auto auto"><span>LP.</span><span>NAZWA</span><span class="c-pts">PUNKTY</span><span class="c-time">CZAS</span></div>
    <div id="rankFull"></div>
    <button class="btn-close" id="btnCloseRank">Zamknij</button>
  </div>
</div>

<script>
// --- Tlo wideo: dekodowanie base64 -> Blob -> obiektowy URL (pewniejsze niz data-URI w <video>) ---
(function(){
  try{
    const b64="";
    const bin=atob(b64);
    const len=bin.length;
    const bytes=new Uint8Array(len);
    for(let i=0;i<len;i++) bytes[i]=bin.charCodeAt(i);
    const blob=new Blob([bytes],{type:"video/mp4"});
    const url=URL.createObjectURL(blob);
    const v=document.querySelector(".bgvid");
    v.src=url;
    const tryPlay=()=>{const pr=v.play&&v.play(); if(pr&&pr.catch)pr.catch(()=>{});};
    v.addEventListener("loadeddata",tryPlay);
    tryPlay();
    // odblokuj odtwarzanie po pierwszej interakcji (mobile autoplay policy)
    const kick=()=>{tryPlay();document.removeEventListener("touchstart",kick);document.removeEventListener("click",kick);};
    document.addEventListener("touchstart",kick,{once:true});
    document.addEventListener("click",kick,{once:true});
    // jesli wideo sie nie wczyta, zostaje statyczne tlo (fallback w tle .app)
    v.addEventListener("error",()=>{v.style.display="none";});
  }catch(e){const v=document.querySelector(".bgvid");if(v)v.style.display="none";}
})();

const LOGO="data:image/png;base64,";
const PAIRS={
  "ball":{label:"Pi\u0142ka",img:"data:image/png;base64,"},
  "player":{label:"Tenisista",img:"data:image/png;base64,"},
  "racket":{label:"Rakieta",img:"data:image/png;base64,"},
  "court":{label:"Kort",img:"data:image/png;base64,"},
  "trophy":{label:"Puchar",img:"data:image/png;base64,"},
  "chair":{label:"Krzes\u0142o s\u0119dziowskie",img:"data:image/png;base64,"},
  "bag":{label:"Torba",img:"data:image/png;base64,"},
  "player2":{label:"Tenisistka",img:"data:image/png;base64,"},
};
const KEYS=Object.keys(PAIRS);
let ranking=[{name:"test",pts:8.00,ms:24960}];
const $=s=>document.querySelector(s);
const screens={start:$("#start"),game:$("#game")};
function show(id){Object.values(screens).forEach(s=>s.classList.remove("active"));screens[id].classList.add("active");}
function fmtTime(ms){const m=Math.floor(ms/60000),s=Math.floor((ms%60000)/1000),mm=ms%1000;
  return String(m).padStart(2,"0")+":"+String(s).padStart(2,"0")+"."+String(mm).padStart(3,"0");}
function esc(s){return String(s).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));}
function renderRankTop(){const box=$("#rankTop");if(!ranking.length){box.innerHTML='<div class="rank-empty">Brak wyników — zagraj pierwszy!</div>';return;}
  const r=[...ranking].sort((a,b)=>b.pts-a.pts||a.ms-b.ms)[0];
  box.innerHTML=`<div class="rank-row"><span class="medal">1</span><span class="nm">${esc(r.name)}</span><span class="pts">${r.pts.toFixed(2)}</span><span class="tm">${fmtTime(r.ms)}</span></div>`;}
function renderRankFull(){const box=$("#rankFull");const s=[...ranking].sort((a,b)=>b.pts-a.pts||a.ms-b.ms);
  if(!s.length){box.innerHTML='<div class="rank-empty">Brak wyników.</div>';return;}
  box.innerHTML=s.map((r,i)=>`<div class="rank-row ${i>0?'alt':''}"><span class="medal">${i+1}</span><span class="nm">${esc(r.name)}</span><span class="pts">${r.pts.toFixed(2)}</span><span class="tm">${fmtTime(r.ms)}</span></div>`).join("");}

const board=$("#board");
let deck=[],first=null,lock=false,moves=0,matched=0,raf=null,startT=0,elapsed=0,finalMs=0;
function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function tick(){elapsed=performance.now()-startT;$("#time").textContent=fmtTime(Math.floor(elapsed));raf=requestAnimationFrame(tick);}
function buildGame(){
  cancelAnimationFrame(raf);
  deck=shuffle(KEYS.flatMap(k=>[k,k]).map((k,i)=>({key:k,id:i})));
  first=null;lock=false;moves=0;matched=0;elapsed=0;
  $("#moves").textContent="0";$("#pairs").textContent="0/8";$("#time").textContent="00:00.000";
  board.innerHTML="";
  deck.forEach(c=>{const b=document.createElement("button");b.className="card";b.setAttribute("aria-label","Zakryta karta");
    b.innerHTML=`<div class="inner"><div class="face front"><img src="${LOGO}" alt="Enea"></div><div class="face back"><img src="${PAIRS[c.key].img}" alt="${esc(PAIRS[c.key].label)}"></div></div>`;
    b.addEventListener("click",()=>flip(b,c));board.appendChild(b);});
  startT=performance.now();raf=requestAnimationFrame(tick);
}
function flip(el,card){
  if(lock||el.classList.contains("flipped")||el.classList.contains("matched"))return;
  el.classList.add("flipped");
  if(!first){first={el,card};return;}
  moves++;$("#moves").textContent=moves;
  if(first.card.key===card.key){first.el.classList.add("matched");el.classList.add("matched");
    matched++;$("#pairs").textContent=matched+"/8";first=null;if(matched===KEYS.length)win();
  }else{lock=true;const a=first.el;setTimeout(()=>{a.classList.remove("flipped");el.classList.remove("flipped");first=null;lock=false;},800);}
}
function win(){cancelAnimationFrame(raf);finalMs=Math.floor(elapsed);
  $("#winPts").textContent=KEYS.length.toFixed(2);$("#winTime").textContent=fmtTime(finalMs);$("#playerName").value="";
  setTimeout(()=>{$("#winOverlay").classList.add("show");$("#playerName").focus();},450);}

$("#btnStart").addEventListener("click",()=>{show("game");buildGame();});
$("#btnRestart").addEventListener("click",buildGame);
$("#btnQuit").addEventListener("click",()=>{cancelAnimationFrame(raf);show("start");});
$("#btnSave").addEventListener("click",()=>{const v=$("#playerName").value.trim()||"Gracz";
  ranking.push({name:v,pts:KEYS.length,ms:finalMs});renderRankTop();renderRankFull();
  $("#winOverlay").classList.remove("show");show("start");$("#rankOverlay").classList.add("show");});
$("#playerName").addEventListener("keydown",e=>{if(e.key==="Enter")$("#btnSave").click();});
$("#rankMore").addEventListener("click",()=>{renderRankFull();$("#rankOverlay").classList.add("show");});
$("#btnCloseRank").addEventListener("click",()=>$("#rankOverlay").classList.remove("show"));
renderRankTop();renderRankFull();
</script>
</body>
</html>
